# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_saas
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_saas

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Gmail API
GMAIL_CREDENTIALS_PATH=data/credentials.json
GMAIL_TOKEN_PATH=data/token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify

# OpenAI (for subject generation and reply classification)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (for autonomous lead discovery - FREE tier: 60 req/min)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Token (for provider discovery - FREE)
# Get your token at: https://github.com/settings/tokens (read-only public repos)
GITHUB_TOKEN=your_github_token_here

# NewsAPI (for buyer discovery - FREE tier)
# Get your key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# FastAPI / Authentication
SECRET_KEY=your_secret_key_here_min_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=10000

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Alerting (Optional but recommended for production)
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ALERT_EMAILS=admin@example.com,ops@example.com
ALERT_SEVERITY_THRESHOLD=warning

# Monitoring (Optional but recommended for production)
SENTRY_DSN=
ENABLE_METRICS=true
METRICS_PORT=9090

# Deliverability Settings
MAX_SENDS_PER_HOUR=30
MAX_SENDS_PER_DAY=200
DOMAIN_WARMUP_DAYS=14

# Lead Qualification
MIN_PRIORITY_SCORE=50
QUALIFICATION_BATCH_SIZE=100

# Backup Settings
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
S3_BUCKET=

# Application
APP_NAME=AI SaaS Outbound
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
